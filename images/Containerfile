# microshift AIO from pre-built MicroShift RPMs
FROM quay.io/centos/centos:stream9

ARG OCP_VERSION
ARG OKD_VERSION
ARG RELEASE_TAG=""
ARG TARBALL_SHA256=""
ARG COPR_PIN=""
ARG WITH_OLM=1

# rpm source is exactly one of:
#   RELEASE_TAG: microshift-io github release rpm tarball (released versions, sha256-pinned)
#   COPR_PIN: exact version-release from the nightly copr (pre-release only, copr prunes old builds)
# guard asserts installed release-info carries OKD_VERSION so source drift fails the build
RUN ARCH=$(uname -m) && \
    if [ -z "${OCP_VERSION}" ]; then \
        echo "OCP_VERSION is required" >&2; exit 1; \
    fi && \
    if [ -z "${OKD_VERSION}" ]; then \
        echo "OKD_VERSION is required" >&2; exit 1; \
    fi && \
    if { [ -n "${RELEASE_TAG}" ] && [ -n "${COPR_PIN}" ]; } || \
       { [ -z "${RELEASE_TAG}" ] && [ -z "${COPR_PIN}" ]; }; then \
        echo "exactly one of RELEASE_TAG or COPR_PIN is required" >&2; exit 1; \
    fi && \
    if [ -n "${RELEASE_TAG}" ] && [ -z "${TARBALL_SHA256}" ]; then \
        echo "TARBALL_SHA256 is required with RELEASE_TAG" >&2; exit 1; \
    fi && \
    printf '[openshift-deps]\nname=OpenShift Dependencies\nbaseurl=https://mirror.openshift.com/pub/openshift-v4/%s/dependencies/rpms/%s-el9-beta/\nenabled=1\ngpgcheck=0\n' \
      "$ARCH" "${OCP_VERSION}" \
      > /etc/yum.repos.d/openshift-deps.repo && \
    if [ -n "${RELEASE_TAG}" ]; then \
        curl -fsSL --retry 5 -o /tmp/rpms.tgz \
          "https://github.com/microshift-io/microshift/releases/download/${RELEASE_TAG}/microshift-rpms-${ARCH}.tgz" && \
        echo "${TARBALL_SHA256}  /tmp/rpms.tgz" | sha256sum -c && \
        mkdir -p /tmp/rpms && \
        tar xzf /tmp/rpms.tgz -C /tmp/rpms --strip-components=1 && \
        printf '[microshift-local]\nname=MicroShift Local\nbaseurl=file:///tmp/rpms\nenabled=1\ngpgcheck=0\n' \
          > /etc/yum.repos.d/microshift.repo && \
        PIN="" ; \
    else \
        printf '[microshift-nightly]\nname=MicroShift Nightly\nbaseurl=https://download.copr.fedorainfracloud.org/results/@microshift-io/microshift-nightly/epel-9-%s/\nenabled=1\ngpgcheck=0\n' \
          "$ARCH" \
          > /etc/yum.repos.d/microshift.repo && \
        PIN="-${COPR_PIN}" ; \
    fi && \
    dnf install -y "microshift${PIN}" "microshift-release-info${PIN}" \
                   "microshift-kindnet${PIN}" "microshift-kindnet-release-info${PIN}" && \
    if [ "${WITH_OLM}" = "1" ] ; then \
        dnf install -y "microshift-olm${PIN}" "microshift-olm-release-info${PIN}" ; \
    fi && \
    rpm -q microshift-release-info | grep -F "$(echo "${OKD_VERSION}" | tr '-' '_')-" && \
    rm -rf /tmp/rpms /tmp/rpms.tgz \
           /etc/yum.repos.d/microshift.repo \
           /etc/yum.repos.d/openshift-deps.repo && \
    dnf clean all

# post-install: firewall, sysctl, CNI plugins, enable microshift
RUN dnf install -y firewalld jq bash-completion skopeo && \
    firewall-offline-cmd --zone=trusted --add-source=10.42.0.0/16 && \
    firewall-offline-cmd --zone=trusted --add-source=169.254.169.1 && \
    firewall-offline-cmd --zone=public --add-port=6443/tcp && \
    firewall-offline-cmd --zone=public --add-port=2379/tcp && \
    firewall-offline-cmd --zone=public --add-port=2380/tcp && \
    printf 'fs.inotify.max_user_watches = 524288\nfs.inotify.max_user_instances = 16384\n' \
      > /etc/sysctl.d/99-microshift.conf && \
    systemctl disable openvswitch 2>/dev/null || true && \
    systemctl disable systemd-resolved 2>/dev/null || true && \
    systemctl enable microshift

# CNI plugins (kindnet needs these)
RUN CNP_VER=v1.8.0 && \
    ARCH=$(uname -m) && \
    if [ "$ARCH" = "aarch64" ]; then CNP_ARCH=arm64; else CNP_ARCH=amd64; fi && \
    curl -sSL --retry 5 -o /tmp/cni.tgz \
      "https://github.com/containernetworking/plugins/releases/download/${CNP_VER}/cni-plugins-linux-${CNP_ARCH}-${CNP_VER}.tgz" && \
    mkdir -p /usr/libexec/cni && \
    tar xzf /tmp/cni.tgz -C /usr/libexec/cni && \
    rm -f /tmp/cni.tgz

# dns base domain
RUN mkdir -p /etc/microshift/config.d && \
    printf 'dns:\n    baseDomain: "127.0.0.1.nip.io"\n' \
      > /etc/microshift/config.d/00-dns.yaml

STOPSIGNAL SIGRTMIN+3
CMD ["/sbin/init"]
